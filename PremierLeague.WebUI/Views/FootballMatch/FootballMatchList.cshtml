@model List<ResultFootballMatchDto>
@{
    ViewData["Title"] = "FootballMatchList";
    Layout = "~/Views/AdminLayout/Index.cshtml";
    var groupedMatches = Model.GroupBy(m => m.WeekId).OrderBy(g => g.Key).ToList();
}
<link href="~/lib/bootstrap/dist/css/bootstrap.min.css" rel="stylesheet" />
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <div class="card-title m-0">Fixture & Match List</div>
        <a href="/FootballMatch/CreateMatch" class="btn btn-primary">
            + Add New Match
        </a>
    </div>

    <div class="card-body">
        <!-- BOOTSTRAP AKORDİYON BAŞLANGICI -->
        <div class="accordion" id="fixtureAccordion">

            @foreach (var group in groupedMatches)
            {
                int weekId = group.Key;

                // 1. Haftanın sekmesi otomatik açık gelsin, diğerleri kapalı dursun
                string isFirstShow = weekId == 1 ? "show" : "";
                string isFirstCollapsed = weekId == 1 ? "" : "collapsed";

                <div class="accordion-item" style="border: 1px solid #eee; margin-bottom: 10px; border-radius: 8px; overflow: hidden;">
                    <h2 class="accordion-header" id="heading-@weekId">
                        <button class="accordion-button @isFirstCollapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapse-@weekId" aria-expanded="true" aria-controls="collapse-@weekId" style="background-color: #f8f9fa; font-weight: bold;">
                            Matchweek @weekId
                            <span class="badge bg-secondary ms-2">@group.Count() Matches</span>
                        </button>
                    </h2>

                    <div id="collapse-@weekId" class="accordion-collapse collapse @isFirstShow" aria-labelledby="heading-@weekId" data-bs-parent="#fixtureAccordion">
                        <div class="accordion-body p-0">

                            <!-- SENİN TABLO TASARIMIN (Tamamen aynı bıraktım) -->
                            <table class="table m-0">
                                <thead style="background-color: #fcfcfc;">
                                    <tr>
                                        <!-- "Week" sütununu kaldırdım çünkü zaten o haftanın sekmesi içindeyiz -->
                                        <th>Match</th>
                                        <th>Date & Time</th>
                                        <th>Stadium</th>
                                        <th>Status</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in group)
                                    {
                                        <tr>
                                            <td>
                                                <div class="match-teams">
                                                    @item.HomeTeamName
                                                    <span class="vs-badge">vs</span>
                                                    @item.AwayTeamName
                                                </div>
                                            </td>

                                            <td>@item.MatchDate.ToString("dd MMM yyyy - HH:mm")</td>

                                            <td>@item.Stadium</td>

                                            <td>
                                                @if (item.Status == "Completed")
                                                {
                                                    <span class="status-pill status-finished"><span class="status-dot"></span>Finished</span>
                                                }
                                                else if (item.Status == "In Progress")
                                                {
                                                    <span class="status-pill status-live"><span class="status-dot"></span>Live</span>
                                                }
                                                else
                                                {
                                                    <span class="status-pill status-upcoming"><span class="status-dot"></span>Upcoming</span>
                                                }
                                            </td>

                                            <td>
                                                <div class="table-action-btns">
                                                    <a href="/FootballMatch/UpdateMatch/@item.Id" class="tbl-btn" style="text-decoration: none;">Edit</a>
                                                    <a href="/FootballMatch/DeleteMatch/@item.Id" class="tbl-btn danger" style="text-decoration: none;">Delete</a>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>

                        </div>
                    </div>
                </div>
            }

        </div>
        <!-- BOOTSTRAP AKORDİYON BİTİŞİ -->
    </div>
</div>
