@model List<ResultTeamDto>
@{
    ViewData["Title"] = "TeamList";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}
<link href="~/lib/bootstrap/dist/css/bootstrap.min.css" rel="stylesheet" />

<style>
    .card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 12px;
        overflow: hidden;
    }

    .card-header {
        padding: 20px 24px;
        border-bottom: 1px solid var(--border);
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .card-title {
        font-size: 18px;
        font-weight: 700;
        color: var(--text-primary);
        margin: 0;
    }

    .btn-primary {
        background: var(--accent);
        color: #fff;
        padding: 8px 16px;
        border-radius: 6px;
        text-decoration: none;
        font-size: 13px;
        font-weight: 600;
        transition: background 0.2s;
    }

        .btn-primary:hover {
            background: var(--accent-hover);
            color: #fff;
        }

    .table-wrap {
        overflow-x: auto;
    }

    .table {
        width: 100%;
        border-collapse: collapse;
        margin: 0;
        font-size: 14px;
    }

        .table th {
            background: rgba(255,255,255,0.02);
            padding: 14px 24px;
            text-align: left;
            font-weight: 600;
            color: var(--text-secondary);
            text-transform: uppercase;
            letter-spacing: 0.5px;
            font-size: 11px;
            border-bottom: 1px solid var(--border);
        }

        .table td {
            padding: 16px 24px;
            border-bottom: 1px solid var(--border);
            color: var(--text-primary);
            vertical-align: middle;
        }

        .table tr:last-child td {
            border-bottom: none;
        }

        .table tr:hover td {
            background: rgba(255,255,255,0.01);
        }

    .team-info {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .team-logo {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        object-fit: contain;
        background: #fff;
        padding: 4px;
        border: 1px solid var(--border);
    }

    .short-name {
        background: rgba(255,255,255,0.05);
        padding: 4px 8px;
        border-radius: 4px;
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 1px;
        color: var(--text-secondary);
    }

    .action-links a {
        text-decoration: none;
        font-weight: 600;
        margin-right: 14px;
        font-size: 13px;
    }

    .btn-edit {
        color: #2979ff;
    }

    .btn-delete {
        color: #ff1744;
    }

    .action-links a:hover {
        opacity: 0.8;
    }
</style>

<div class="card">
    <div class="card-header">
        <h3 class="card-title">Manage Teams</h3>
        <a href="/Team/CreateTeam" class="btn-primary">+ Add New Team</a>
    </div>

    <div class="table-wrap">
        <table class="table">
            <thead>
                <tr>
                    <th>Team</th>
                    <th>Short Name</th>
                    <th>City</th>
                    <th>Stadium</th>
                    <th>Founded</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                <div class="team-info">
                                    @if (!string.IsNullOrEmpty(item.LogoUrl))
                                    {
                                        <img src="@item.LogoUrl" alt="@item.Name" class="team-logo" onerror="this.src='https://ui-avatars.com/api/?name=@item.Name&background=random'" />
                                    }
                                    else
                                    {
                                        <img src="https://ui-avatars.com/api/?name=@item.Name&background=random" alt="@item.Name" class="team-logo" />
                                    }
                                    <strong>@item.Name</strong>
                                </div>
                            </td>
                            <td><span class="short-name">@item.ShortName</span></td>
                            <td>@item.City</td>
                            <td>@item.Stadium</td>
                            <td>@item.FoundedYear</td>
                            <td class="action-links">
                                <a href="/Team/UpdateTeam/@item.Id" class="btn-edit">Edit</a>
                                <a href="/Team/DeleteTeam/@item.Id" class="btn-delete" onclick="return confirm('Are you sure you want to delete this team?');">Delete</a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" style="text-align: center; padding: 30px; color: var(--text-secondary);">
                            No teams found. Click "Add New Team" to create one.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
