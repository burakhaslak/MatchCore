@model PremierLeague.DtoLayer.FootballMatchDtos.ResultFootballMatchDto

@if (Model != null)
{
    <div class="feat-wrap" id="featWrap">
        <div class="feat-lbl">Featured Match</div>
        <a href="match-detail.html" class="feat-card">
            <div class="row align-items-center g-2">

                <!-- EV SAHİBİ (HOME) -->
                <div class="col-5">
                    <div class="ft-team">
                        <div class="ft-logo" style="border-color:rgba(239,1,7,.4)">
                            <img src="@Model.HomeTeamLogo" alt="@Model.HomeTeamName" onerror="this.parentNode.textContent='@Model.HomeTeamName'" />
                        </div>
                        <div class="ft-name">@Model.HomeTeamName</div>
                        <div class="ft-type">Home</div>
                    </div>
                </div>

                <!-- SKOR VE DURUM -->
                <div class="col-2 text-center">
                    <div class="ft-sc-area">
                        <!-- Skoru DTO'daki property'ne göre buraya basıyorsun (Örn: Model.MatchScore) -->
                        <div class="ft-sc">@Model.HomeScore–@Model.AwayScore</div>

                        <div class="ft-stat">
                            @if (Model.Status == "Completed")
                            {
                                <span><i class="bi bi-check2-circle"></i> FULL TIME</span>
                            }
                            else if (Model.Status == "In Progress")
                            {
                                <span><span class="live-dot"></span> LIVE</span>
                            }
                            else
                            {
                                <span><i class="bi bi-calendar"></i> UPCOMING</span>
                            }
                        </div>

                        <div class="ft-meta">HT: @Model.FirstHalfScore &nbsp;·&nbsp; @Model.MatchDate.ToString("HH:mm")</div>
                    </div>
                </div>

                <!-- DEPLASMAN (AWAY) -->
                <div class="col-5">
                    <div class="ft-team">
                        <div class="ft-logo" style="border-color:rgba(200,16,46,.4)">
                            <img src="@Model.AwayTeamLogo" alt="@Model.AwayTeamName" onerror="this.parentNode.textContent='@Model.AwayTeamName'" />
                        </div>
                        <div class="ft-name">@Model.AwayTeamName</div>
                        <div class="ft-type">Away</div>
                    </div>
                </div>

            </div>

            <!-- STADYUM VE TARİH -->
            <div class="text-center mt-3" style="font-size:12px;color:var(--t2)">
                <i class="bi bi-geo-alt"></i> @Model.Stadium &nbsp;·&nbsp;
                <i class="bi bi-calendar3"></i> @Model.MatchDate.ToString("dd MMMM yyyy") &nbsp;·&nbsp;
                <span style="color:var(--blue)">View Details →</span>
            </div>
        </a>
    </div>
}