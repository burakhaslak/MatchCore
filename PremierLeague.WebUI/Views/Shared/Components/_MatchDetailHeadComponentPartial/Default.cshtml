<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>MatchCore Match Details</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;500;600;700;800;900&family=Barlow:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <style>
        :root {
            --bg: #080d18;
            --bg2: #0c1220;
            --card: #111827;
            --card2: #16202f;
            --elevated: #1c2d42;
            --green: #00e676;
            --blue: #2979ff;
            --live: #ff1744;
            --gold: #ffd600;
            --yellow: #ffc107;
            --red: #f44336;
            --t1: #eef2ff;
            --t2: #7b96c4;
            --t3: #3d5478;
            --border: #1a2640;
            --r1: 8px;
            --r2: 12px;
            --r3: 16px;
            --shadow: 0 4px 24px rgba(0,0,0,.5);
            --tr: all .22s cubic-bezier(.4,0,.2,1);
            --fd: 'Barlow Condensed',sans-serif;
            --fb: 'Barlow',sans-serif;
        }

        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0
        }

        html {
            scroll-behavior: smooth
        }

        body {
            font-family: var(--fb);
            background: var(--bg);
            color: var(--t1);
            min-height: 100vh;
            background-image: radial-gradient(ellipse at 15% 0%,rgba(41,121,255,.07) 0%,transparent 55%), radial-gradient(ellipse at 85% 0%,rgba(0,230,118,.04) 0%,transparent 50%)
        }

        ::-webkit-scrollbar {
            width: 5px
        }

        ::-webkit-scrollbar-track {
            background: var(--bg)
        }

        ::-webkit-scrollbar-thumb {
            background: var(--elevated);
            border-radius: 3px
        }

        a {
            text-decoration: none;
            color: inherit
        }

        img {
            display: block
        }

        /* ── NAVBAR ── */
        .nb {
            background: rgba(8,13,24,.96);
            backdrop-filter: blur(20px);
            border-bottom: 1px solid var(--border);
            position: sticky;
            top: 0;
            z-index: 1000;
            box-shadow: 0 2px 24px rgba(0,0,0,.5)
        }

        .nb-inner {
            max-width: 1120px;
            margin: 0 auto;
            padding: 0 20px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 16px
        }

        .brand {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 14px 0
        }

        .brand-ico {
            width: 34px;
            height: 34px;
            background: linear-gradient(135deg,var(--green),var(--blue));
            border-radius: 7px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 17px
        }

        .brand-txt {
            font-family: var(--fd);
            font-size: 21px;
            font-weight: 800;
            letter-spacing: 1px
        }

            .brand-txt span {
                color: var(--green)
            }

        .nav-links {
            display: flex
        }

        .nl {
            font-family: var(--fd);
            font-size: 12px;
            font-weight: 700;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            color: var(--t2);
            padding: 22px 15px;
            position: relative;
            transition: var(--tr)
        }

            .nl::after {
                content: '';
                position: absolute;
                bottom: 0;
                left: 15px;
                right: 15px;
                height: 2px;
                background: var(--green);
                transform: scaleX(0);
                transition: var(--tr)
            }

            .nl:hover, .nl.active {
                color: var(--t1)
            }

                .nl:hover::after, .nl.active::after {
                    transform: scaleX(1)
                }

        .nb-icons {
            display: flex;
            align-items: center;
            gap: 5px
        }

        .ico-btn {
            width: 36px;
            height: 36px;
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: var(--r1);
            color: var(--t2);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 14px;
            transition: var(--tr)
        }

            .ico-btn:hover {
                background: var(--elevated);
                color: var(--t1);
                border-color: var(--blue)
            }

        .tog {
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: var(--r1);
            padding: 7px 9px;
            color: var(--t1);
            cursor: pointer;
            line-height: 1
        }

        .mob-menu {
            max-height: 0;
            overflow: hidden;
            transition: max-height .3s ease
        }

            .mob-menu.open {
                max-height: 320px
            }

            .mob-menu .nl {
                padding: 14px 0;
                border-bottom: 1px solid var(--border);
                display: block
            }

        /* ── WRAP ── */
        .wrap {
            max-width: 1120px;
            margin: 0 auto;
            padding: 0 20px
        }

        /* ── HERO ── */
        .hero {
            background: linear-gradient(180deg,#0b1830 0%,var(--bg) 100%);
            border-bottom: 1px solid var(--border);
            padding: 36px 0 28px;
            position: relative;
            overflow: hidden
        }

            .hero::before {
                content: '';
                position: absolute;
                inset: 0;
                background: radial-gradient(ellipse at 20% 50%,rgba(0,230,118,.05) 0%,transparent 60%), radial-gradient(ellipse at 80% 50%,rgba(41,121,255,.05) 0%,transparent 60%);
                pointer-events: none
            }

        .hero-badges {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            margin-bottom: 26px;
            flex-wrap: wrap
        }

        .hbadge {
            font-family: var(--fd);
            font-size: 10px;
            font-weight: 700;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            padding: 4px 12px;
            border-radius: 20px
        }

        .hb-gold {
            background: rgba(255,214,0,.09);
            border: 1px solid rgba(255,214,0,.2);
            color: var(--gold)
        }

        .hb-gray {
            background: rgba(143,163,200,.08);
            color: var(--t3)
        }

        .hb-green {
            background: rgba(0,230,118,.08);
            border: 1px solid rgba(0,230,118,.18);
            color: var(--green)
        }

        .hero-grid {
            display: grid;
            grid-template-columns: 1fr auto 1fr;
            gap: 20px;
            align-items: center
        }

        .h-team {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 12px
        }

        .h-logo {
            width: 86px;
            height: 86px;
            border-radius: 50%;
            background: var(--card);
            border: 2px solid var(--border);
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: var(--fd);
            font-size: 24px;
            font-weight: 900;
            overflow: hidden
        }

            .h-logo img {
                width: 100%;
                height: 100%;
                object-fit: contain;
                padding: 8px
            }

        .h-name {
            font-family: var(--fd);
            font-size: clamp(18px,3vw,26px);
            font-weight: 900;
            letter-spacing: .3px;
            text-align: center
        }

        .h-type {
            font-size: 10px;
            color: var(--t3);
            text-transform: uppercase;
            letter-spacing: 1.5px;
            font-weight: 600
        }

        .h-score-c {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 10px
        }

        .h-sc {
            font-family: var(--fd);
            font-size: clamp(54px,10vw,88px);
            font-weight: 900;
            letter-spacing: -4px;
            line-height: 1;
            background: linear-gradient(180deg,#fff 0%,#8fa3c8 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text
        }

        .h-ht {
            font-family: var(--fd);
            font-size: 12px;
            color: var(--t2);
            background: var(--card);
            padding: 4px 14px;
            border-radius: 11px;
            border: 1px solid var(--border)
        }

        .h-ft {
            font-family: var(--fd);
            font-size: 12px;
            font-weight: 700;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            color: var(--t3)
        }

        .info-strip {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 22px;
            margin-top: 22px;
            padding-top: 18px;
            border-top: 1px solid var(--border);
            flex-wrap: wrap
        }

        .istrip {
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: 12px;
            color: var(--t2)
        }

            .istrip i {
                color: var(--t3);
                font-size: 13px
            }

        /* ── CONTENT ── */
        .content {
            padding: 28px 0 56px
        }

        .dc {
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: var(--r3);
            padding: 22px;
            margin-bottom: 18px
        }

        .dc-title {
            font-family: var(--fd);
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 2px;
            text-transform: uppercase;
            color: var(--t3);
            margin-bottom: 18px;
            display: flex;
            align-items: center;
            gap: 10px
        }

            .dc-title::after {
                content: '';
                flex: 1;
                height: 1px;
                background: var(--border)
            }

        /* ── TIMELINE ── */
        .tl-wrap {
            position: relative
        }

        .tl-line {
            position: absolute;
            left: 50%;
            top: 0;
            bottom: 0;
            width: 1px;
            background: var(--border);
            transform: translateX(-50%)
        }

        .tl-ev {
            display: grid;
            grid-template-columns: 1fr 58px 1fr;
            gap: 10px;
            align-items: center;
            margin-bottom: 10px;
            animation: fadeUp .4s ease both
        }

        @@keyframes fadeUp {
            from {
                opacity: 0;
                transform: translateY(8px)
            }

            to {
                opacity: 1;
                transform: none
            }
        }

        .tl-ev:nth-child(1) {
            animation-delay: .05s
        }

        .tl-ev:nth-child(2) {
            animation-delay: .1s
        }

        .tl-ev:nth-child(3) {
            animation-delay: .15s
        }

        .tl-ev:nth-child(4) {
            animation-delay: .2s
        }

        .tl-ev:nth-child(5) {
            animation-delay: .25s
        }

        .tl-ev:nth-child(6) {
            animation-delay: .3s
        }

        .tl-ev:nth-child(7) {
            animation-delay: .35s
        }

        .tl-ev:nth-child(8) {
            animation-delay: .4s
        }

        .tl-ev:nth-child(9) {
            animation-delay: .45s
        }

        .tl-ev:nth-child(10) {
            animation-delay: .5s
        }

        .tl-ev:nth-child(11) {
            animation-delay: .55s
        }

        .tl-home {
            display: flex;
            justify-content: flex-end
        }

        .tl-away {
            display: flex;
            justify-content: flex-start
        }

        .tl-min-c {
            display: flex;
            align-items: center;
            justify-content: center
        }

        .min-b {
            background: var(--elevated);
            border: 1px solid var(--border);
            border-radius: 11px;
            padding: 3px 8px;
            font-family: var(--fd);
            font-size: 11px;
            font-weight: 700;
            color: var(--t2);
            white-space: nowrap;
            position: relative;
            z-index: 1
        }

        .chip {
            display: flex;
            align-items: center;
            gap: 7px;
            background: var(--elevated);
            border: 1px solid var(--border);
            border-radius: var(--r1);
            padding: 8px 11px;
            max-width: 210px
        }

            .chip.home {
                flex-direction: row-reverse;
                text-align: right
            }

            .chip.goal-ev {
                border-color: rgba(0,230,118,.25);
                background: rgba(0,230,118,.06)
            }

            .chip.yel-ev {
                border-color: rgba(255,193,7,.25);
                background: rgba(255,193,7,.06)
            }

            .chip.red-ev {
                border-color: rgba(244,67,54,.25);
                background: rgba(244,67,54,.06)
            }

            .chip.sub-ev {
                border-color: rgba(41,121,255,.2);
                background: rgba(41,121,255,.05)
            }

        .ev-ico {
            width: 26px;
            height: 26px;
            border-radius: 6px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 13px;
            flex-shrink: 0
        }

        .ei-goal {
            background: rgba(0,230,118,.15);
            color: var(--green)
        }

        .ei-yel {
            background: rgba(255,193,7,.15);
            color: var(--yellow)
        }

        .ei-red {
            background: rgba(244,67,54,.15);
            color: var(--red)
        }

        .ei-sub {
            background: rgba(41,121,255,.12);
            color: var(--blue)
        }

        .ev-pl {
            font-family: var(--fd);
            font-size: 14px;
            font-weight: 700;
            color: var(--t1)
        }

        .ev-dt {
            font-size: 10px;
            color: var(--t3)
        }

        /* ── GOALS / CARDS ── */
        .split2 {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 14px
        }

        .box2 {
            padding: 14px;
            background: var(--bg2);
            border-radius: var(--r2);
            border: 1px solid var(--border)
        }

        .box2-title {
            font-family: var(--fd);
            font-size: 10px;
            font-weight: 700;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            color: var(--t3);
            margin-bottom: 10px
        }

        .gl {
            display: flex;
            align-items: center;
            gap: 9px;
            padding: 6px 0;
            border-bottom: 1px solid rgba(255,255,255,.04)
        }

            .gl:last-child {
                border-bottom: none
            }

        .gl-ico {
            width: 20px;
            height: 20px;
            background: rgba(0,230,118,.12);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 10px;
            color: var(--green);
            flex-shrink: 0
        }

        .gl-pl {
            font-family: var(--fd);
            font-size: 14px;
            font-weight: 700;
            flex: 1
        }

        .gl-min {
            font-family: var(--fd);
            font-size: 11px;
            font-weight: 700;
            color: var(--t3);
            background: var(--elevated);
            padding: 2px 7px;
            border-radius: 7px
        }

        .ycard {
            width: 12px;
            height: 16px;
            background: var(--yellow);
            border-radius: 2px;
            flex-shrink: 0;
            box-shadow: 0 2px 5px rgba(255,193,7,.3)
        }

        .rcard {
            width: 12px;
            height: 16px;
            background: var(--red);
            border-radius: 2px;
            flex-shrink: 0;
            box-shadow: 0 2px 5px rgba(244,67,54,.3)
        }

        /* ── SUBSTITUTIONS ── */
        .sub-r {
            display: flex;
            align-items: center;
            gap: 11px;
            padding: 9px 0;
            border-bottom: 1px solid rgba(255,255,255,.04)
        }

            .sub-r:last-child {
                border-bottom: none
            }

        .sub-min {
            font-family: var(--fd);
            font-size: 12px;
            font-weight: 700;
            color: var(--t3);
            background: var(--elevated);
            padding: 3px 9px;
            border-radius: 9px;
            width: 46px;
            text-align: center;
            flex-shrink: 0
        }

        .sub-in {
            font-family: var(--fd);
            font-size: 13px;
            font-weight: 700;
            color: var(--green)
        }

        .sub-out {
            font-family: var(--fd);
            font-size: 13px;
            font-weight: 700;
            color: var(--live)
        }

        .sub-arr {
            color: var(--t3);
            font-size: 15px
        }

        .sub-lbl {
            font-family: var(--fd);
            font-size: 10px;
            font-weight: 700;
            letter-spacing: 1px;
            text-transform: uppercase;
            color: var(--t3);
            margin: 14px 0 6px;
            padding-top: 10px;
            border-top: 1px solid var(--border)
        }

            .sub-lbl:first-child {
                margin-top: 0;
                padding-top: 0;
                border-top: none
            }

        /* ── STATS ── */
        .stat-r {
            display: grid;
            grid-template-columns: 1fr auto 1fr;
            gap: 10px;
            align-items: center;
            margin-bottom: 12px
        }

        .sv-h {
            font-family: var(--fd);
            font-size: 17px;
            font-weight: 800;
            text-align: right
        }

        .sv-a {
            font-family: var(--fd);
            font-size: 17px;
            font-weight: 800;
            text-align: left
        }

        .sl {
            font-size: 10px;
            font-weight: 600;
            letter-spacing: 1px;
            text-transform: uppercase;
            color: var(--t3);
            text-align: center;
            white-space: nowrap
        }

        .bar-r {
            display: grid;
            grid-template-columns: 1fr 20px 1fr;
            gap: 7px;
            align-items: center;
            margin-bottom: 12px
        }

        .bh {
            height: 3px;
            background: var(--elevated);
            border-radius: 2px;
            overflow: hidden;
            display: flex;
            justify-content: flex-end
        }

            .bh .f {
                height: 100%;
                background: linear-gradient(90deg,var(--blue),#6aabff);
                border-radius: 2px;
                transition: width 1.1s ease
            }

        .ba {
            height: 3px;
            background: var(--elevated);
            border-radius: 2px;
            overflow: hidden
        }

            .ba .f {
                height: 100%;
                background: linear-gradient(90deg,#ff6b6b,var(--live));
                border-radius: 2px;
                transition: width 1.1s ease
            }

        /* ── MATCH INFO BOX ── */
        .mi-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 9px 0;
            border-bottom: 1px solid var(--border);
            font-size: 13px
        }

            .mi-row:last-child {
                border-bottom: none
            }

        .mi-key {
            color: var(--t3)
        }

        .mi-val {
            font-family: var(--fd);
            font-size: 14px;
            font-weight: 700;
            text-align: right
        }

        /* ── SCORE PILLS ── */
        .sc-pills {
            display: grid;
            grid-template-columns: repeat(3,1fr);
            gap: 8px;
            margin-bottom: 4px
        }

        .sc-pill {
            background: var(--bg2);
            border-radius: var(--r2);
            padding: 11px;
            text-align: center;
            border: 1px solid var(--border)
        }

        .sp-lbl {
            font-family: var(--fd);
            font-size: 10px;
            color: var(--t3);
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 3px
        }

        .sp-val {
            font-family: var(--fd);
            font-size: 22px;
            font-weight: 900
        }

        /* ── BACK BTN ── */
        .back-btn {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: var(--r2);
            color: var(--t2);
            padding: 10px 18px;
            font-family: var(--fd);
            font-size: 12px;
            font-weight: 700;
            letter-spacing: 1px;
            text-transform: uppercase;
            transition: var(--tr);
            margin-bottom: 22px
        }

            .back-btn:hover {
                background: var(--elevated);
                border-color: var(--blue);
                color: var(--t1)
            }

        /* ── FOOTER ── */
        .ft {
            background: var(--bg2);
            border-top: 1px solid var(--border);
            padding: 44px 0 22px;
            margin-top: 36px
        }

        .ft-brand {
            font-family: var(--fd);
            font-size: 20px;
            font-weight: 800;
            margin-bottom: 8px
        }

            .ft-brand span {
                color: var(--green)
            }

        .ft-desc {
            font-size: 12px;
            color: var(--t3);
            line-height: 1.7;
            max-width: 240px
        }

        .ft-h {
            font-family: var(--fd);
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 2px;
            text-transform: uppercase;
            color: var(--t2);
            margin-bottom: 14px
        }

        .ft-ul {
            list-style: none;
            padding: 0
        }

            .ft-ul li {
                margin-bottom: 7px
            }

            .ft-ul a {
                color: var(--t3);
                font-size: 12px;
                transition: var(--tr)
            }

                .ft-ul a:hover {
                    color: var(--t1)
                }

        .si-row {
            display: flex;
            gap: 7px;
            margin-top: 14px
        }

        .si {
            width: 34px;
            height: 34px;
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: var(--r1);
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--t3);
            transition: var(--tr);
            font-size: 13px
        }

            .si:hover {
                background: var(--elevated);
                color: var(--green);
                border-color: var(--green)
            }

        .ft-bot {
            border-top: 1px solid var(--border);
            padding-top: 18px;
            margin-top: 32px;
            font-size: 11px;
            color: var(--t3);
            display: flex;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 6px
        }

        /* ── RESPONSIVE ── */
        @@media(max - width:768px) {
            .hero-grid {
                gap: 10px
            }

            .h-logo {
                width: 60px;
                height: 60px
            }

            .h-name {
                font-size: 14px
            }

