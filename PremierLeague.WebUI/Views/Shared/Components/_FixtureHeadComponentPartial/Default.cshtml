<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Fixture — MatchCore Premier League</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;500;600;700;800;900&family=Barlow:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <style>
        :root {
            --bg: #080d18;
            --bg2: #0c1220;
            --card: #111827;
            --card2: #16202f;
            --elevated: #1c2d42;
            --green: #00e676;
            --blue: #2979ff;
            --live: #ff1744;
            --gold: #ffd600;
            --yellow: #ffc107;
            --red: #f44336;
            --t1: #eef2ff;
            --t2: #7b96c4;
            --t3: #3d5478;
            --border: #1a2640;
            --r1: 8px;
            --r2: 12px;
            --r3: 16px;
            --tr: all .22s cubic-bezier(.4,0,.2,1);
            --fd: 'Barlow Condensed',sans-serif;
            --fb: 'Barlow',sans-serif;
        }

        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0
        }

        html {
            scroll-behavior: smooth
        }

        body {
            font-family: var(--fb);
            background: var(--bg);
            color: var(--t1);
            min-height: 100vh;
            background-image: radial-gradient(ellipse at 15% 0%,rgba(41,121,255,.07) 0%,transparent 55%), radial-gradient(ellipse at 85% 0%,rgba(0,230,118,.04) 0%,transparent 50%)
        }

        ::-webkit-scrollbar {
            width: 5px
        }

        ::-webkit-scrollbar-track {
            background: var(--bg)
        }

        ::-webkit-scrollbar-thumb {
            background: var(--elevated);
            border-radius: 3px
        }

        a {
            text-decoration: none;
            color: inherit
        }

        img {
            display: block
        }

        /* ── NAVBAR ── */
        .nb {
            background: rgba(8,13,24,.96);
            backdrop-filter: blur(20px);
            border-bottom: 1px solid var(--border);
            position: sticky;
            top: 0;
            z-index: 1000;
            box-shadow: 0 2px 24px rgba(0,0,0,.5)
        }

        .nb-inner {
            max-width: 1120px;
            margin: 0 auto;
            padding: 0 20px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 16px
        }

        .brand {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 14px 0
        }

        .brand-ico {
            width: 34px;
            height: 34px;
            background: linear-gradient(135deg,var(--green),var(--blue));
            border-radius: 7px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 17px
        }

        .brand-txt {
            font-family: var(--fd);
            font-size: 21px;
            font-weight: 800;
            letter-spacing: 1px
        }

            .brand-txt span {
                color: var(--green)
            }

        .nav-links {
            display: flex
        }

        .nl {
            font-family: var(--fd);
            font-size: 12px;
            font-weight: 700;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            color: var(--t2);
            padding: 22px 15px;
            position: relative;
            transition: var(--tr)
        }

            .nl::after {
                content: '';
                position: absolute;
                bottom: 0;
                left: 15px;
                right: 15px;
                height: 2px;
                background: var(--green);
                transform: scaleX(0);
                transition: var(--tr)
            }

            .nl:hover, .nl.active {
                color: var(--t1)
            }

                .nl:hover::after, .nl.active::after {
                    transform: scaleX(1)
                }

        .nb-icons {
            display: flex;
            align-items: center;
            gap: 5px
        }

        .ico-btn {
            width: 36px;
            height: 36px;
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: var(--r1);
            color: var(--t2);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 14px;
            transition: var(--tr)
        }

            .ico-btn:hover {
                background: var(--elevated);
                color: var(--t1);
                border-color: var(--blue)
            }

        .tog {
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: var(--r1);
            padding: 7px 9px;
            color: var(--t1);
            cursor: pointer;
            line-height: 1
        }

        .mob-menu {
            max-height: 0;
            overflow: hidden;
            transition: max-height .3s ease
        }

            .mob-menu.open {
                max-height: 320px
            }

            .mob-menu .nl {
                padding: 14px 0;
                border-bottom: 1px solid var(--border);
                display: block
            }

        .wrap {
            max-width: 1120px;
            margin: 0 auto;
            padding: 0 20px
        }

        /* ── PAGE HEADER ── */
        .pg-head {
            background: linear-gradient(135deg,var(--bg2),var(--card));
            border-bottom: 1px solid var(--border);
            padding: 32px 0 24px;
            position: relative;
            overflow: hidden
        }

            .pg-head::before {
                content: '';
                position: absolute;
                top: -40%;
                right: -5%;
                width: 380px;
                height: 380px;
                background: radial-gradient(circle,rgba(41,121,255,.05) 0%,transparent 70%);
                pointer-events: none
            }

        .pg-badge {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            background: rgba(255,214,0,.09);
            border: 1px solid rgba(255,214,0,.22);
            border-radius: 20px;
            padding: 4px 12px;
            font-family: var(--fd);
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 1px;
            color: var(--gold);
            text-transform: uppercase;
            margin-bottom: 10px
        }

        .pg-title {
            font-family: var(--fd);
            font-size: clamp(26px,5vw,42px);
            font-weight: 900;
            letter-spacing: .5px;
            line-height: 1
        }

        .pg-sub {
            font-size: 13px;
            color: var(--t2);
            margin-top: 6px
        }

        /* ── WEEK NAV ── */
        .week-nav {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-top: 16px
        }

        .wn-btn {
            display: flex;
            align-items: center;
            gap: 6px;
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: var(--r1);
            padding: 8px 14px;
            font-family: var(--fd);
            font-size: 12px;
            font-weight: 700;
            letter-spacing: 1px;
            text-transform: uppercase;
            color: var(--t2);
            cursor: pointer;
            transition: var(--tr)
        }

            .wn-btn:hover {
                background: var(--elevated);
                color: var(--t1);
                border-color: var(--blue)
            }

        .wn-cur {
            font-family: var(--fd);
            font-size: 16px;
            font-weight: 800;
            color: var(--t1);
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: var(--r1);
            padding: 8px 20px;
            letter-spacing: .5px
        }

        /* ── COUNTDOWN STRIP ── */
        .countdown-strip {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 6px;
            background: rgba(41,121,255,.06);
            border: 1px solid rgba(41,121,255,.15);
            border-radius: var(--r2);
            padding: 12px 20px;
            margin: 24px 0 0;
            flex-wrap: wrap
        }

        .cd-label {
            font-family: var(--fd);
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            color: var(--t3)
        }

        .cd-box {
            background: var(--elevated);
            border-radius: var(--r1);
            padding: 6px 14px;
            text-align: center
        }

        .cd-num {
            font-family: var(--fd);
            font-size: 22px;
            font-weight: 900;
            color: var(--blue);
            line-height: 1
        }

        .cd-unit {
            font-size: 9px;
            color: var(--t3);
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-top: 2px
        }

        .cd-sep {
            font-family: var(--fd);
            font-size: 22px;
            font-weight: 900;
            color: var(--t3)
        }

        /* ── CONTENT ── */
        .content {
            padding: 28px 0 56px
        }

        /* ── DAY GROUP ── */
        .day-group {
            margin-bottom: 28px
        }

        .day-header {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 12px
        }

        .day-title {
            font-family: var(--fd);
            font-size: 13px;
            font-weight: 800;
            letter-spacing: 2px;
            text-transform: uppercase;
            color: var(--t2)
        }

        .day-date {
            font-family: var(--fd);
            font-size: 12px;
            color: var(--t3);
            letter-spacing: 1px
        }

        .day-line {
            flex: 1;
            height: 1px;
            background: var(--border)
        }

        .day-badge {
            font-family: var(--fd);
            font-size: 10px;
            font-weight: 700;
            letter-spacing: 1px;
            text-transform: uppercase;
            padding: 3px 10px;
            border-radius: 8px;
            white-space: nowrap
        }

        .db-today {
            background: rgba(0,230,118,.1);
            border: 1px solid rgba(0,230,118,.2);
            color: var(--green)
        }

        .db-tomorrow {
            background: rgba(41,121,255,.1);
            border: 1px solid rgba(41,121,255,.2);
            color: var(--blue)
        }

        .db-sun {
            background: rgba(255,214,0,.08);
            border: 1px solid rgba(255,214,0,.18);
            color: var(--gold)
        }

        /* ── FIXTURE CARD ── */
        .fx-card {
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: var(--r2);
            padding: 0;
            margin-bottom: 8px;
            overflow: hidden;
            transition: var(--tr);
            position: relative
        }

            .fx-card:hover {
                background: var(--card2);
                border-color: rgba(41,121,255,.3);
                transform: translateY(-1px);
                box-shadow: 0 6px 24px rgba(0,0,0,.4)
            }

            .fx-card.top-match {
                border-color: rgba(255,214,0,.22);
                background: linear-gradient(135deg,var(--card),rgba(255,214,0,.03))
            }

                .fx-card.top-match:hover {
                    border-color: rgba(255,214,0,.4)
                }

        .fx-top-badge {
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 2px;
            background: linear-gradient(90deg,var(--gold),transparent)
        }

        .fx-inner {
            display: flex;
            align-items: center;
            padding: 14px 18px;
            gap: 0
        }

        /* time column */
        .fx-time-col {
            width: 72px;
            flex-shrink: 0;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 4px
        }

        .fx-time {
            font-family: var(--fd);
            font-size: 16px;
            font-weight: 700;
            color: var(--t2)
        }

        .fx-day-label {
            font-family: var(--fd);
            font-size: 9px;
            font-weight: 700;
            letter-spacing: .8px;
            text-transform: uppercase;
            color: var(--t3)
        }

        .fx-divider {
            width: 1px;
            height: 44px;
            background: var(--border);
            margin: 0 16px;
            flex-shrink: 0
        }

        /* teams area */
        .fx-teams {
            flex: 1;
            min-width: 0;
            display: grid;
            grid-template-columns: 1fr auto 1fr;
            align-items: center;
            gap: 8px
        }

        .fx-team-home {
            display: flex;
            align-items: center;
            gap: 10px;
            justify-content: flex-end
        }

        .fx-team-away {
            display: flex;
            align-items: center;
            gap: 10px
        }

        .fx-name {
            font-family: var(--fd);
            font-size: 16px;
            font-weight: 700;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis
        }

            .fx-name.home {
                text-align: right
            }

        .fx-logo {
            width: 28px;
            height: 28px;
            border-radius: 50%;
            background: var(--elevated);
            border: 1px solid var(--border);
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: var(--fd);
            font-size: 9px;
            font-weight: 800;
            color: var(--t2);
            overflow: hidden;
            flex-shrink: 0
        }

            .fx-logo img {
                width: 100%;
                height: 100%;
                object-fit: contain;
                padding: 3px
            }

        .vs-block {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 2px;
            flex-shrink: 0
        }

        .vs-text {
            font-family: var(--fd);
            font-size: 13px;
            font-weight: 800;
            color: var(--t3)
        }

        .vs-time-sm {
            font-family: var(--fd);
            font-size: 10px;
            color: var(--t3)
        }

        /* right side */
        .fx-right {
            display: flex;
            flex-direction: column;
            align-items: flex-end;
            gap: 6px;
            margin-left: 14px;
            flex-shrink: 0
        }

        .fx-stadium {
            font-size: 11px;
            color: var(--t3);
            text-align: right;
            max-width: 140px;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis
        }

        .notify-btn {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            background: rgba(41,121,255,.08);
            border: 1px solid rgba(41,121,255,.2);
            color: var(--blue);
            border-radius: var(--r1);
            padding: 5px 10px;
            font-family: var(--fd);
            font-size: 10px;
            font-weight: 700;
            letter-spacing: .8px;
            text-transform: uppercase;
            cursor: pointer;
            transition: var(--tr)
        }

            .notify-btn:hover {
                background: rgba(41,121,255,.18);
                color: var(--blue)
            }

            .notify-btn.active {
                background: rgba(0,230,118,.1);
                border-color: rgba(0,230,118,.3);
                color: var(--green)
            }

        /* top match ribbon */
        .top-match-tag {
            font-family: var(--fd);
            font-size: 9px;
            font-weight: 800;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            color: var(--gold);
            background: rgba(255,214,0,.08);
            border: 1px solid rgba(255,214,0,.2);
            padding: 2px 8px;
            border-radius: 7px
        }

        /* ── H2H MINI ── */
        .h2h-strip {
            background: var(--bg2);
            border-top: 1px solid var(--border);
            padding: 8px 18px;
            display: flex;
            align-items: center;
            gap: 10px;
            flex-wrap: wrap
        }

        .h2h-label {
            font-family: var(--fd);
            font-size: 9px;
            font-weight: 700;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            color: var(--t3);
            white-space: nowrap
        }

        .h2h-pills {
            display: flex;
            gap: 4px
        }

        .h2h-p {
            width: 22px;
            height: 22px;
            border-radius: 5px;
            font-family: var(--fd);
            font-size: 11px;
            font-weight: 800;
            display: flex;
            align-items: center;
            justify-content: center
        }

        .h2h-w {
            background: rgba(0,230,118,.15);
            color: var(--green)
        }

        .h2h-d {
            background: rgba(123,150,196,.12);
            color: var(--t2)
        }

        .h2h-l {
            background: rgba(255,23,68,.12);
            color: var(--live)
        }

        .h2h-avg {
            font-family: var(--fd);
            font-size: 11px;
            color: var(--t3);
            margin-left: auto
        }

        /* ── KEY PLAYERS STRIP ── */
        .kp-strip {
            background: var(--bg2);
            border-top: 1px solid var(--border);
            padding: 8px 18px;
            display: flex;
            align-items: center;
            gap: 12px;
            flex-wrap: wrap
        }

        .kp-label {
            font-family: var(--fd);
            font-size: 9px;
            font-weight: 700;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            color: var(--t3);
            white-space: nowrap
        }

        .kp-tag {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            background: var(--elevated);
            border: 1px solid var(--border);
            border-radius: 7px;
            padding: 4px 9px;
            font-family: var(--fd);
            font-size: 11px;
            font-weight: 700;
            color: var(--t2)
        }

            .kp-tag i {
                font-size: 10px;
                color: var(--green)
            }

        /* ── WEEK SUMMARY CARD ── */
        .week-summary {
            display: grid;
            grid-template-columns: repeat(4,1fr);
            gap: 12px;
            margin-bottom: 24px
        }

        .ws-card {
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: var(--r2);
            padding: 16px;
            text-align: center
        }

        .ws-num {
            font-family: var(--fd);
            font-size: 26px;
            font-weight: 900;
            line-height: 1
        }

        .ws-lbl {
            font-size: 11px;
            color: var(--t3);
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-top: 4px;
            font-weight: 600
        }

        /* ── FOOTER ── */
        .ft {
            background: var(--bg2);
            border-top: 1px solid var(--border);
            padding: 44px 0 22px;
            margin-top: 0
        }

        .ft-brand {
            font-family: var(--fd);
            font-size: 20px;
            font-weight: 800;
            margin-bottom: 8px
        }

            .ft-brand span {
                color: var(--green)
            }

        .ft-desc {
            font-size: 12px;
            color: var(--t3);
            line-height: 1.7;
            max-width: 240px
        }

        .ft-h {
            font-family: var(--fd);
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 2px;
            text-transform: uppercase;
            color: var(--t2);
            margin-bottom: 14px
        }

        .ft-ul {
            list-style: none;
            padding: 0
        }

            .ft-ul li {
                margin-bottom: 7px
            }

            .ft-ul a {
                color: var(--t3);
                font-size: 12px;
                transition: var(--tr)
            }

                .ft-ul a:hover {
                    color: var(--t1)
                }

        .si-row {
            display: flex;
            gap: 7px;
            margin-top: 14px
        }

        .si {
            width: 34px;
            height: 34px;
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: var(--r1);
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--t3);
            transition: var(--tr);
            font-size: 13px
        }

            .si:hover {
                background: var(--elevated);
                color: var(--green);
                border-color: var(--green)
            }

        .ft-bot {
            border-top: 1px solid var(--border);
            padding-top: 18px;
            margin-top: 32px;
            font-size: 11px;
            color: var(--t3);
            display: flex;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 6px
        }

        /* ── RESPONSIVE ── */
        @@media(max - width,:768px) {
            .fx-right .fx-stadium {
                display: none
            }

            .week-summary {
                grid-template-columns: repeat(2,1fr)
            }

            .kp-strip, .h2h-strip {
                display: none
            }

            .fx-name {
                font-size: 13px
            }

            .fx-time {
                font-size: 14px
            }
        }

        @@media(max - width,:500px) {
            .fx-teams {
                gap: 4px
            }

            .fx-name {
                font-size: 12px
            }

            .fx-logo {
                width: 22px;
                height: 22px
            }

            .week-summary {
                grid-template-columns: repeat(2,1fr);
                gap: 8px
            }

            .ws-num {
                font-size: 20px
            }

            .notify-btn span {
                display: none
            }

            .fx-right {
                margin-left: 8px
            }
        }
    </style>
</head>