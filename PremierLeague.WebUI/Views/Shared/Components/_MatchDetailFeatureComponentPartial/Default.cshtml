@model PremierLeague.DtoLayer.MatchDetailDtos.MatchDetailHeaderDto

<style>
    .match-hero {
        padding: 40px 0 30px 0;
        border-bottom: 1px solid rgba(255,255,255,0.05);
    }

    .mh-badges {
        display: flex;
        justify-content: center;
        gap: 10px;
        margin-bottom: 30px;
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 1px;
    }

    .mh-badge {
        padding: 6px 14px;
        border-radius: 20px;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        border: 1px solid rgba(255,255,255,0.1);
    }

        .mh-badge.gold {
            border-color: rgba(255,214,0,0.4);
            color: #ffd600;
        }

        .mh-badge.dark {
            background: rgba(255,255,255,0.05);
            color: #adb5bd;
        }

        .mh-badge.green {
            border-color: rgba(0,255,135,0.4);
            color: #00ff87;
        }

    .team-circle {
        width: 110px;
        height: 110px;
        border-radius: 50%;
        padding: 12px;
        background: rgba(255,255,255,0.03);
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 15px auto;
    }

        .team-circle.home-c {
            border: 2px solid #e30613;
        }
        /* Ev sahibi için kırmızı vurgu */
        .team-circle.away-c {
            border: 2px solid #00529f;
        }
        /* Deplasman için mavi vurgu */
        .team-circle img {
            max-width: 100%;
            max-height: 100%;
            object-fit: contain;
        }

    .team-name {
        color: #fff;
        font-size: 26px;
        font-weight: 800;
        margin-bottom: 4px;
    }

    .team-lbl {
        color: #6c757d;
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 2px;
    }

    .score-txt {
        font-size: 72px;
        font-weight: 900;
        color: #fff;
        line-height: 1;
        font-family: 'Impact', sans-serif;
        letter-spacing: 2px;
        margin-bottom: 12px;
    }

    .ht-badge {
        display: inline-block;
        border: 1px solid rgba(255,255,255,0.15);
        border-radius: 20px;
        padding: 4px 14px;
        color: #adb5bd;
        font-size: 12px;
        font-weight: 600;
        margin-bottom: 12px;
    }

    .mh-info-row {
        border-top: 1px solid rgba(255,255,255,0.08);
        padding-top: 20px;
        display: flex;
        justify-content: center;
        gap: 35px;
        color: #8a939b;
        font-size: 13px;
        font-weight: 500;
    }

        .mh-info-row i {
            color: #00529f;
            font-size: 14px;
        }
</style>

@if (Model != null && Model.MatchId > 0)
{
    <section class="match-hero">
        <div class="wrap text-center">

            <!-- ÜST BİLGİ ETİKETLERİ -->
            <div class="mh-badges">
                <span class="mh-badge gold"><i class="bi bi-trophy-fill"></i> PREMIER LEAGUE - MATCHWEEK @Model.WeekId</span>
                <span class="mh-badge dark"><i class="bi bi-check-circle"></i> @Model.Status.ToUpper()</span>
                @if (Model.Attendance > 0)
                {
                    <span class="mh-badge green"><i class="bi bi-people-fill"></i> @Model.Attendance?.ToString("N0") ATTENDANCE</span>
                }
            </div>

            <!-- SKORBORD -->
            <div class="row align-items-center mb-5">

                <!-- EV SAHİBİ -->
                <div class="col-4">
                    <div class="team-circle home-c">
                        <img src="@Model.HomeTeamLogo" alt="@Model.HomeTeamName" onerror="this.style.display='none'" />
                    </div>
                    <div class="team-name">@Model.HomeTeamName</div>
                    <div class="team-lbl">HOME</div>
                </div>

                <!-- SKOR -->
                <div class="col-4">
                    <div class="score-txt">
                        @Model.HomeScore - @Model.AwayScore
                    </div>
                    <div class="ht-badge">
                        <i class="bi bi-hourglass-split"></i> HT: @Model.HomeScoreHT-@Model.AwayScoreHT
                    </div>
                    <div class="team-lbl" style="color:#adb5bd">FULL TIME</div>
                </div>

                <!-- DEPLASMAN -->
                <div class="col-4">
                    <div class="team-circle away-c">
                        <img src="@Model.AwayTeamLogo" alt="@Model.AwayTeamName" onerror="this.style.display='none'" />
                    </div>
                    <div class="team-name">@Model.AwayTeamName</div>
                    <div class="team-lbl">AWAY</div>
                </div>

            </div>

            <!-- ALT SATIR BİLGİLERİ (Stadyum, Tarih, Hakem) -->
            <div class="mh-info-row">
                <span><i class="bi bi-geo-alt"></i> @Model.Stadium</span>
                <span><i class="bi bi-calendar3"></i> @Model.MatchDate.ToString("dd MMMM yyyy")</span>
                <span><i class="bi bi-clock"></i> @Model.MatchDate.ToString("HH:mm")</span>
                <span><i class="bi bi-person-badge"></i> @Model.Referee</span>
            </div>

        </div>
    </section>
}