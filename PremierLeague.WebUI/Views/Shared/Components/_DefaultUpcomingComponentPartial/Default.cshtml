@model List<PremierLeague.DtoLayer.FootballMatchDtos.ResultFootballMatchDto>


@if (Model != null && Model.Any())
{
    <div class="sec-ttl mcw-section" data-s="upcoming" style="margin-top:22px">🕐 &nbsp;Upcomıng Matches</div>

    @foreach (var item in Model)
    {
        <div class="mc-wrap mcw" data-s="upcoming">
            <a href="/Match/Detail/@item.Id" class="mc">
                <div class="mc-time">
                    <div class="mc-min bc">@item.MatchDate.ToString("HH:mm")</div>

                    <div class="sbadge sb-up">
                        @if (item.MatchDate.Date == DateTime.Today)
                        {
                            <text>TODAY</text>
                        }
                        else if (item.MatchDate.Date == DateTime.Today.AddDays(1))
                        {
                            <text>TOMORROW</text>
                        }
                        else
                        {
                            <text>@item.MatchDate.ToString("dd MMM")</text>
                        }
                    </div>
                </div>
                <div class="dvv"></div>
                <div class="mc-teams">

                    <div class="mc-tr">
                        <div class="tl-sm">
                            <img src="@item.HomeTeamLogo" alt="@item.HomeTeamName" onerror="this.parentNode.textContent='@item.HomeTeamName'" />
                        </div>
                        <span class="tn">@item.HomeTeamName</span>
                        <span class="ts dim">—</span>
                    </div>

                    <div class="mc-tr">
                        <div class="tl-sm">
                            <img src="@item.AwayTeamLogo" alt="@item.AwayTeamName" onerror="this.parentNode.textContent='@item.AwayTeamName'" />
                        </div>
                        <span class="tn">@item.AwayTeamName</span>
                        <span class="ts dim">—</span>
                    </div>

                </div>

                <div class="det-btn"><i class="bi bi-calendar-check"></i> <span>Preview</span></div>
            </a>
        </div>
    }
}