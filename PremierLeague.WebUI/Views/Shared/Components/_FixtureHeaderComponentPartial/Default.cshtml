@model PremierLeague.DtoLayer.FixtureDtos.FixturePageDto

<!-- PAGE HEADER -->
<section class="pg-head">
    <div class="wrap">
        <div class="row align-items-end">
            <div class="col-lg-7">
                <div class="pg-badge"><i class="bi bi-trophy-fill"></i> PREMIER LEAGUE</div>
                <h1 class="pg-title">Matchweek <span style="color:var(--blue)">@Model.ActiveWeek</span> Fixtures</h1>

                <p class="pg-sub">@Model.WeekStartDate.ToString("dd MMMM") – @Model.WeekEndDate.ToString("dd MMMM yyyy") &nbsp;·&nbsp; @Model.TotalMatchesInWeek Matches</p>

                <div class="week-nav">

                    <!-- GERİ BUTONU -->
                    @if (Model.ActiveWeek > 1)
                    {
                        <a href="?weekId=@(Model.ActiveWeek - 1)" class="wn-btn">
                            <i class="bi bi-chevron-left"></i> <span>Matchweek @(Model.ActiveWeek - 1)</span>
                        </a>
                    }

                    <div class="wn-cur">Matchweek @Model.ActiveWeek</div>

                    <!-- İLERİ BUTONU -->
                    @if (Model.ActiveWeek < Model.TotalWeeksInSeason)
                    {
                        <a href="?weekId=@(Model.ActiveWeek + 1)" class="wn-btn">
                            <span>Matchweek @(Model.ActiveWeek + 1)</span> <i class="bi bi-chevron-right"></i>
                        </a>
                    }

                </div>
            </div>

            <div class="col-lg-5 mt-3 mt-lg-0">
                <div class="countdown-strip">
                    <span class="cd-label">FIRST MATCH</span>
                    <div class="cd-box"><div class="cd-num" id="cd-d">00</div><div class="cd-unit">DAYS</div></div>
                    <span class="cd-sep">:</span>
                    <div class="cd-box"><div class="cd-num" id="cd-h">00</div><div class="cd-unit">HOURS</div></div>
                    <span class="cd-sep">:</span>
                    <div class="cd-box"><div class="cd-num" id="cd-m">00</div><div class="cd-unit">MINS</div></div>
                    <span class="cd-sep">:</span>
                    <div class="cd-box"><div class="cd-num" id="cd-s">00</div><div class="cd-unit">SECS</div></div>
                </div>
            </div>
        </div>
    </div>
</section>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script>
    // Mobile nav
    const tog = document.getElementById('tog');
    const mob = document.getElementById('mobMenu');
    tog.addEventListener('click', () => {
      mob.classList.toggle('open');
      tog.innerHTML = mob.classList.contains('open')
        ? '<i class="bi bi-x-lg"></i>' : '<i class="bi bi-list"></i>';
    });

    // Navbar shadow
    window.addEventListener('scroll', () => {
      document.querySelector('.nb').style.boxShadow =
        window.scrollY > 8 ? '0 4px 32px rgba(0,0,0,.7)' : '0 2px 24px rgba(0,0,0,.5)';
    });

    // Notify toggle
    function toggleNotify(btn) {
      const isActive = btn.classList.contains('active');
      if (isActive) {
        btn.classList.remove('active');
        btn.innerHTML = '<i class="bi bi-bell"></i> <span>Bildir</span>';
      } else {
        btn.classList.add('active');
        btn.innerHTML = '<i class="bi bi-bell-fill"></i> <span>Bildirim Açık</span>';
      }
    }

    const targetDateString = '@(Model.NextMatchDateIso ?? "")';

     function updateCountdown() {
       // Eğer veritabanında hiç oynanmamış maç kalmadıysa sayaç 0'da dursun
       if (!targetDateString) {
         return;
       }

       const target = new Date(targetDateString);
       const now = new Date();
       const diff = target - now;

       if (diff <= 0) {
         document.getElementById('cd-d').textContent = '00';
         document.getElementById('cd-h').textContent = '00';
         document.getElementById('cd-m').textContent = '00';
         document.getElementById('cd-s').textContent = '00';
         return;
       }

       const d = Math.floor(diff / 86400000);
       const h = Math.floor((diff % 86400000) / 3600000);
       const m = Math.floor((diff % 3600000) / 60000);
       const s = Math.floor((diff % 60000) / 1000);

       document.getElementById('cd-d').textContent = String(d).padStart(2,'0');
       document.getElementById('cd-h').textContent = String(h).padStart(2,'0');
       document.getElementById('cd-m').textContent = String(m).padStart(2,'0');
       document.getElementById('cd-s').textContent = String(s).padStart(2,'0');
     }

     updateCountdown();
     setInterval(updateCountdown, 1000);

    // Card animate in
    document.querySelectorAll('.fx-card').forEach((c, i) => {
      c.style.opacity = '0';
      c.style.transform = 'translateY(12px)';
      setTimeout(() => {
        c.style.transition = 'opacity .35s ease, transform .35s ease';
        c.style.opacity = '1';
        c.style.transform = 'translateY(0)';
      }, 50 + i * 60);
    });

    //geri sayım falan filan

</script>