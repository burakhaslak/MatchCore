@model List<PremierLeague.DtoLayer.FootballMatchDtos.ResultFootballMatchDto>

@if (Model != null && Model.Any())
{
    <div class="sec-ttl mcw-section" data-s="finished" style="margin-top:22px">✅ &nbsp;Fınıshed Matches</div>

    @foreach (var item in Model)
    {
        <div class="mc-wrap mcw" data-s="finished">
            <a href="/MatchDetail/Index/@item.Id" class="mc">
                <div class="mc-time">
                    <div class="mc-min">@item.MatchDate.ToString("HH:mm")</div>
                    <div class="sbadge sb-fin">FT</div>
                </div>
                <div class="dvv"></div>
                <div class="mc-teams">

                    <div class="mc-tr">
                        <div class="tl-sm">
                            <img src="@item.HomeTeamLogo" alt="@item.HomeTeamName" onerror="this.parentNode.textContent='@item.HomeTeamName'" />
                        </div>
                        <span class="tn">@item.HomeTeamName</span>
                        <span class="ts @(item.HomeScore > item.AwayScore ? "win" : "")">@item.HomeScore</span>
                    </div>

                    <div class="mc-tr">
                        <div class="tl-sm">
                            <img src="@item.AwayTeamLogo" alt="@item.AwayTeamName" onerror="this.parentNode.textContent='@item.AwayTeamName'" />
                        </div>
                        <span class="tn">@item.AwayTeamName</span>
                        <span class="ts @(item.AwayScore > item.HomeScore ? "win" : "")">@item.AwayScore</span>
                    </div>

                </div>
                <div class="det-btn"><i class="bi bi-chevron-right"></i> <span>Details</span></div>
            </a>
        </div>
    }
}